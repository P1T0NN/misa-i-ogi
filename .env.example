# --- Convex env (Dashboard: https://dashboard.convex.dev -> your deployment -> Settings -> Environment Variables) ---
# Public R2 base URL for public bucket access (R2.dev subdomain or custom domain). NO trailing slash.
# If unset, uploaded file rows get signed GET URLs that expire (~15m default / 7d fallback), which is bad for stored cover images.
# Example: https://pub-c0fc3574f37d43b6944793bac1e6d018.r2.dev
# R2_PUBLIC_BASE_URL=

# Guest stay - set these in Convex env, not SvelteKit env:
# - SITE_URL: public SvelteKit origin used as the guest JWT issuer.
# - GUEST_STAY_COOKIE_SECRET: `openssl rand -base64 32`
# - GUEST_CONVEX_AUTH_PRIVATE_JWK: `bun run generate:guest-auth-key`

# Set automatically by `bunx convex dev` on first run; the CLI will fill these in.
CONVEX_DEPLOYMENT=
PUBLIC_CONVEX_URL=

# --- Search input (SvelteKit remote + Convex rate limit bridge) ---
# Shared secret between SvelteKit and Convex for trusted search rate-limit calls.
# Generate: `openssl rand -base64 32`
SEARCH_INPUT_RATE_LIMIT_SECRET=

# --- App ---
# Public URL of the SvelteKit app. Better Auth uses this to build OAuth callback
# URLs and verification links. In dev: http://localhost:5173
SITE_URL=http://localhost:5173

# Must match Convex SITE_URL in production, including protocol and www choice.
# Exposed to the browser for admin QR generation (activate links).
PUBLIC_SITE_URL=http://localhost:5173

# --- Better Auth ---
# 32+ char random string. Generate: `openssl rand -base64 32`
BETTER_AUTH_SECRET=

# --- Google OAuth ---
# Google Cloud Console -> APIs & Services -> Credentials -> OAuth 2.0 Client ID
# Authorized redirect URI: ${SITE_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Resend (transactional email) ---
# https://resend.com/api-keys
RESEND_API_KEY=
