# Normalize all text files to LF — keeps prettier (`endOfLine: "lf"` default),
# Windows checkouts (core.autocrlf), and CI byte-identical.
* text=auto eol=lf

# Binary assets — never normalize.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.avif binary
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary
*.pdf binary
*.zip binary
*.pen binary
